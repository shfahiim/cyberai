<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>cyberai - {{.Target}}</title>
<style>
  :root {
    --bg: #0f1115;
    --bg-card: #161a22;
    --bg-soft: #1d2230;
    --fg: #e8ecf2;
    --fg-dim: #8b94a7;
    --border: #2a3142;
    --crit: #ff4d4d;
    --high: #ff7a59;
    --med:  #f5b800;
    --low:  #4ea1ff;
    --info: #6ad48a;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    background: var(--bg); color: var(--fg);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
    line-height: 1.5;
  }
  .container { max-width: 1100px; margin: 0 auto; padding: 32px 24px 80px; }
  h1 { font-size: 28px; margin: 0 0 8px; }
  h2 { font-size: 20px; margin: 32px 0 12px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
  h3 { font-size: 16px; margin: 24px 0 8px; }
  .meta { color: var(--fg-dim); font-size: 13px; margin: 4px 0; }
  .meta code { color: var(--fg); background: var(--bg-soft); padding: 1px 6px; border-radius: 3px; }
  .summary {
    display: grid; grid-template-columns: repeat(5, 1fr);
    gap: 8px; margin: 16px 0 24px;
  }
  .count {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 6px; padding: 12px 14px;
  }
  .count .n { font-size: 28px; font-weight: 600; line-height: 1.1; }
  .count .label { color: var(--fg-dim); font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
  .crit .n { color: var(--crit); }
  .high .n { color: var(--high); }
  .med  .n { color: var(--med);  }
  .low  .n { color: var(--low);  }
  .info .n { color: var(--info); }
  .finding {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 6px;
    padding: 14px 16px; margin: 8px 0;
  }
  .finding-head { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .finding-head .title { font-weight: 600; flex: 1; }
  .sev { font-size: 11px; padding: 2px 8px; border-radius: 999px; text-transform: uppercase; letter-spacing: 0.5px; }
  .sev.crit { background: var(--crit); color: #fff; }
  .sev.high { background: var(--high); color: #fff; }
  .sev.med  { background: var(--med); color: #1a1a1a; }
  .sev.low  { background: var(--low); color: #fff; }
  .sev.info { background: var(--info); color: #0f1115; }
  .finding .file { color: var(--fg-dim); font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace; font-size: 13px; }
  .finding .meta-row { color: var(--fg-dim); font-size: 12px; margin-top: 4px; }
  .finding pre {
    background: var(--bg-soft); border: 1px solid var(--border); border-radius: 4px;
    padding: 10px 12px; overflow-x: auto; font-size: 12.5px;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
  }
  .empty { color: var(--fg-dim); padding: 24px; text-align: center; }
  .scanners { font-size: 13px; }
  .scanners .row { display: flex; gap: 10px; padding: 6px 0; border-bottom: 1px solid var(--border); }
  .scanners .row:last-child { border: 0; }
  .scanners .name { font-weight: 600; min-width: 100px; }
  .scanners .cat { color: var(--fg-dim); min-width: 100px; }
  .summary-banner {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 6px;
    padding: 16px 18px; margin: 16px 0;
  }
  .summary-banner .llm { color: var(--info); font-size: 12px; }
  a { color: var(--low); text-decoration: none; }
  a:hover { text-decoration: underline; }
  .ref-list { font-size: 12px; color: var(--fg-dim); }
</style>
</head>
<body>
<div class="container">
  <h1>cyberai scan report</h1>
  <div class="meta"><strong>Target:</strong> <code>{{.Target}}</code></div>
  <div class="meta"><strong>Project hash:</strong> <code>{{.Hash}}</code></div>
  <div class="meta"><strong>Generated:</strong> {{.GeneratedAt.Format "2006-01-02 15:04:05 UTC"}}</div>
  <div class="meta"><strong>Duration:</strong> {{.Duration}}</div>
  {{- if .SuppressedByIgnore}}
  <div class="meta"><strong>Suppressed by ignore patterns:</strong> {{.SuppressedByIgnore}}</div>
  {{- end}}

  {{- if .SummaryHTML}}
  <div class="summary-banner">
    <strong>Executive summary</strong>
    <div class="llm">(generated by LLM)</div>
    <div>{{.SummaryHTML}}</div>
  </div>
  {{- end}}

  <h2>Severity summary</h2>
  <div class="summary">
    {{- if eq (index .Counts "critical") 0}}{{- else}}
    <div class="count crit"><div class="n">{{index .Counts "critical"}}</div><div class="label">Critical</div></div>
    {{- end}}
    {{- if eq (index .Counts "high") 0}}{{- else}}
    <div class="count high"><div class="n">{{index .Counts "high"}}</div><div class="label">High</div></div>
    {{- end}}
    {{- if eq (index .Counts "medium") 0}}{{- else}}
    <div class="count med"><div class="n">{{index .Counts "medium"}}</div><div class="label">Medium</div></div>
    {{- end}}
    {{- if eq (index .Counts "low") 0}}{{- else}}
    <div class="count low"><div class="n">{{index .Counts "low"}}</div><div class="label">Low</div></div>
    {{- end}}
    {{- if eq (index .Counts "info") 0}}{{- else}}
    <div class="count info"><div class="n">{{index .Counts "info"}}</div><div class="label">Info</div></div>
    {{- end}}
  </div>

  <h2>Scanners</h2>
  <div class="scanners">
    {{- range .Scanners}}
    <div class="row">
      <span class="name">{{.Tool}}</span>
      <span class="cat">{{.Category}}{{if .Skipped}} - skipped{{else if .Error}} - error{{end}}</span>
      <span>
        {{- if .Skipped -}}{{.SkipReason}}
        {{- else if .Error -}}{{.Error}}
        {{- else -}}{{len .Findings}} findings in {{.Duration}}
        {{- end}}
      </span>
    </div>
    {{- end}}
  </div>

  <h2>Findings</h2>
  {{- if not .Findings}}
  <div class="empty">No findings at or above the configured threshold.</div>
  {{- else}}
    {{- range .Findings}}
    <div class="finding">
      <div class="finding-head">
        <span class="title">{{.Title}}</span>
        <span class="sev {{.Severity}}">{{.Severity}}</span>
      </div>
      <div class="file">{{.File}}:{{.StartLine}}{{if .Column}}:{{.Column}}{{end}}</div>
      <div class="meta-row">
        {{.Tool}} · <code>{{.RuleID}}</code>
        {{- if .CVE}} · {{range .CVE}}{{.}} {{end}}{{end}}
        {{- if .CWE}} · {{range .CWE}}{{.}} {{end}}{{end}}
        {{- if .CVSS}} · CVSS {{printf "%.1f" .CVSS}}{{end}}
      </div>
      {{- if .Description}}
      <p>{{.Description}}</p>
      {{- end}}
      {{- if .Fix}}
      <p><strong>Suggested fix:</strong> {{.Fix}}</p>
      {{- end}}
      {{- if .Snippet}}
      <pre>{{.Snippet}}</pre>
      {{- end}}
      {{- if .References}}
      <div class="ref-list">
        {{- range .References}}
        <div>· <a href="{{.}}">{{.}}</a></div>
        {{- end}}
      </div>
      {{- end}}
    </div>
    {{- end}}
  {{- end}}
</div>
</body>
</html>
