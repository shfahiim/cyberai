      "category": "sast",
      "severity": "high",
      "bug_class": "path_traversal",
      "file": "app/main.py",
      "line_hint": "download_file",
      "expected_tools": ["semgrep"],
      "description": "User-controlled filename is joined into a filesystem path without safe normalization."
    },
    {
