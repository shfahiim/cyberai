{
  "schema_version": 1,
  "project": "python-api",
  "description": "Ground truth for the intentionally vulnerable CyberAI Python benchmark.",
  "findings": [
    {
      "id": "PY-SQLI-001",
      "category": "sast",
      "severity": "critical",
      "bug_class": "sql_injection",
      "file": "app/main.py",
      "line_hint": "search_users",
      "expected_tools": ["semgrep"],
      "description": "Query parameter q is interpolated directly into a SQL query."
    },
    {
      "id": "PY-CMD-001",
      "category": "sast",
      "severity": "critical",
      "bug_class": "command_injection",
      "file": "app/main.py",
